{
  "name": "css-calipers",
  "version": "0.0.0",
  "description": "Reserved package name placeholder for the upcoming CSS-Calipers unit-safety toolkit for CSS.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slafleche/css-calipers.git"
  },
  "bugs": {
    "url": "https://github.com/slafleche/css-calipers/issues"
  },
  "homepage": "https://github.com/slafleche/css-calipers#readme",
  "author": "slafleche",
  "keywords": [
    "css",
    "units",
    "typescript",
    "measurement",
    "safety",
    "calipers",
    "type-safe",
    "css-calipers"
  ],
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "scripts": {
    "build:cjs": "tsc -p tsconfig.build.cjs.json",
    "build:esm": "tsc -p tsconfig.build.esm.json",
    "build": "npm run build:cjs && npm run build:esm",
    "prepublishOnly": "node -e \"if (!process.env.CSS_CALIPERS_RELEASE) { console.error('Direct npm publish is disabled; use \\\"npm run release\\\" instead.'); process.exit(1); }\" && npm test && npm run build",
    "release": "node scripts/release.mjs",
    "release:dry": "node scripts/release.mjs --dry-run",
    "test": "vitest"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.14",
    "typescript": "^5.6.3",
    "vitest": "^4.0.14"
  },
  "type": "commonjs"
}
