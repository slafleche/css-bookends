{
  "name": "@css-bookends/spacing",
  "version": "0.1.0",
  "description": "Typed padding / margin / gap builder with axis shorthands. The spacing lexicon of CSS-Bookends.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slafleche/css-bookends.git",
    "directory": "lexicons/spacing"
  },
  "author": "slafleche",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "type": "commonjs",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "@css-bookends/css-calipers": "workspace:^"
  },
  "devDependencies": {
    "@css-bookends/css-calipers": "workspace:*",
    "@css-bookends/eslint-config": "workspace:*",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  },
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p tsconfig.build.cjs.json",
    "build:esm": "tsc -p tsconfig.build.esm.json && node scripts/emit-esm-package.mjs",
    "test": "npm run build && npm run test:src && npm run test:tsc && npm run lint",
    "test:src": "vitest run tests/runtime/spacing.src.test.ts",
    "test:tsc": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0"
  }
}
