{
  "name": "@css-bookends/media-queries",
  "version": "0.1.0",
  "description": "Experimental media query helpers, built on css-calipers. Part of the CSS-Bookends umbrella.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slafleche/css-bookends.git",
    "directory": "books/media-queries"
  },
  "author": "slafleche",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "type": "commonjs",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "css-calipers": "workspace:*",
    "csstype": "^3.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^9.39.2",
    "tsd": "^0.33.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  },
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p tsconfig.build.cjs.json",
    "build:esm": "tsc -p tsconfig.build.esm.json && node scripts/emit-esm-package.mjs",
    "test": "npm run build && npm run test:src && npm run test:dist && npm run test:types && npm run test:tsc && npm run lint",
    "test:src": "vitest run tests/runtime/mediaQueries/mediaQueries.src.test.ts",
    "test:dist": "vitest run tests/runtime/mediaQueries/mediaQueries.cjs.test.ts tests/runtime/mediaQueries/mediaQueries.esm.test.ts tests/runtime/mediaQueries.api-surface.cjs.test.ts tests/runtime/mediaQueries.api-surface.esm.test.ts",
    "test:types": "tsd --files tests/types/**/*.test-d.ts",
    "test:tsc": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0"
  }
}
