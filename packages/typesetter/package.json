{
  "name": "@css-bookends/typesetter",
  "version": "0.1.0",
  "description": "Typesetter (v0): the low-level mechanical converters that set a single DTCG (Design Tokens Format Module, 2025.10) token into the most-constrained-yet-accurate CSS-Bookends calipers primitive. No document parser, no :root generator, no orchestration; just convertToken().",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/css-bookends/css-bookends.git",
    "directory": "packages/typesetter"
  },
  "bugs": {
    "url": "https://github.com/css-bookends/css-bookends/issues"
  },
  "homepage": "https://github.com/css-bookends/css-bookends#readme",
  "author": "slafleche",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "css",
    "bookends",
    "design-tokens",
    "dtcg",
    "typed",
    "css-in-js"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "type": "commonjs",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "@css-bookends/css-calipers": "workspace:^"
  },
  "devDependencies": {
    "@css-bookends/css-calipers": "workspace:*",
    "@css-bookends/eslint-config": "workspace:*",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  },
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p tsconfig.build.cjs.json",
    "build:esm": "tsc -p tsconfig.build.esm.json && node scripts/emit-esm-package.mts",
    "test": "npm run build && npm run test:unit && npm run test:tsc && npm run lint",
    "test:unit": "vitest run tests",
    "test:tsc": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0"
  }
}
