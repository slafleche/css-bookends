{
  "name": "@css-bookends/gilding",
  "version": "0.1.0",
  "description": "Gilding: the CSS-Bookends finisher. A build-time pass that wraps a CSS post-processor (default: Lightning CSS) to complete browser compatibility (older-browser color fallbacks and vendor prefixes) over the plain CSS books emit.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/css-bookends/css-bookends.git",
    "directory": "packages/gilding"
  },
  "bugs": {
    "url": "https://github.com/css-bookends/css-bookends/issues"
  },
  "homepage": "https://github.com/css-bookends/css-bookends#readme",
  "author": "slafleche",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "css",
    "bookends",
    "postcss",
    "lightningcss",
    "fallback",
    "autoprefixer"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "type": "commonjs",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "browserslist": "^4.24.0",
    "lightningcss": "^1.32.0"
  },
  "devDependencies": {
    "@css-bookends/css-calipers": "workspace:*",
    "@css-bookends/eslint-config": "workspace:*",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  },
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p tsconfig.build.cjs.json",
    "build:esm": "tsc -p tsconfig.build.esm.json && node scripts/emit-esm-package.mts",
    "test": "npm run build && npm run test:unit && npm run test:tsc && npm run lint",
    "test:unit": "vitest run tests",
    "test:tsc": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0"
  }
}
