{
  "name": "@css-bookends/shelf",
  "version": "0.1.0",
  "description": "The whole CSS-Bookends shelf: a metapackage that re-exports every lexicon and book.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slafleche/css-bookends.git",
    "directory": "packages/shelf"
  },
  "bugs": {
    "url": "https://github.com/slafleche/css-bookends/issues"
  },
  "homepage": "https://github.com/slafleche/css-bookends#readme",
  "author": "slafleche",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "css",
    "bookends",
    "typed",
    "css-in-js"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "type": "commonjs",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@css-bookends/colours": "workspace:*",
    "@css-bookends/css-calipers": "workspace:*",
    "@css-bookends/media-queries": "workspace:*"
  },
  "devDependencies": {
    "@css-bookends/eslint-config": "workspace:*",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  },
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p tsconfig.build.cjs.json",
    "build:esm": "tsc -p tsconfig.build.esm.json && node scripts/emit-esm-package.mjs",
    "test": "npm run build && npm run test:smoke && npm run test:tsc && npm run lint",
    "test:smoke": "vitest run tests/smoke.test.ts",
    "test:tsc": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0"
  }
}
